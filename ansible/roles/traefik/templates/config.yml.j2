http:
  middlewares:    
    default-security-headers:
      headers:
        customBrowserXSSValue: 0                            # X-XSS-Protection=1; mode=block
        contentTypeNosniff: true                          # X-Content-Type-Options=nosniff
        forceSTSHeader: true                              # Add the Strict-Transport-Security header even when the connection is HTTP
        frameDeny: false                                   # X-Frame-Options=deny
        referrerPolicy: "strict-origin-when-cross-origin"
        stsIncludeSubdomains: true                        # Add includeSubdomains to the Strict-Transport-Security header
        stsPreload: true                                  # Add preload flag appended to the Strict-Transport-Security header
        stsSeconds: 3153600                              # Set the max-age of the Strict-Transport-Security header (63072000 = 2 years)
        contentSecurityPolicy: "default-src 'self'"     
        customRequestHeaders:
          X-Forwarded-Proto: https
    https-redirectscheme:
      redirectScheme:
        scheme: https
        permanent: true

  routers:
    gateway:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`gateway.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: gateway


    pm:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`pm.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: pm
    pm1:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`pm1.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: pm1
    pm2:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`pm2.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: pm2
    pm3:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`pm3.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: pm3

    dns:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`dns.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: dns
    dns1:
      entryPoints:
       - "web"
       - "websecure"
      rule: Host(`dns1.{{ configurations.dns_zone }}`)
      middlewares:
        # - default-security-headers
        - https-redirectscheme
      tls:
        certresolver: cloudflare
      service: dns1
    dns2:
